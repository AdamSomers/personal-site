---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Building — Adam Somers" description="Active AI projects exploring persistent context as a second mind.">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <Breadcrumb items={[{ label: 'Building' }]} />

    <h1 class="font-heading text-3xl sm:text-4xl font-bold mb-4 text-text dark:text-dark-text">
      What I'm Building
    </h1>

    <p class="text-lg text-text-medium dark:text-dark-text-medium leading-relaxed mb-10 max-w-2xl">
      All three projects explore the same idea: AI gets dramatically more useful with persistent, structured context. A second mind that knows your ongoing situation.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {projects.map((project) => (
        <ProjectCard
          slug={project.id.replace(/\.mdx?$/, '')}
          title={project.data.title}
          hook={project.data.hook}
          status={project.data.status}
          techStack={project.data.techStack}
        />
      ))}
    </div>
  </div>
</BaseLayout>
