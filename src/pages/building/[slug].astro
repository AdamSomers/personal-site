---
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id.replace(/\.mdx?$/, '') },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

// Fetch last commit date from the project's GitHub repo
let lastUpdated = project.data.lastUpdated || '';
if (project.data.github) {
  try {
    const match = project.data.github.match(/github\.com\/([^/]+\/[^/]+)/);
    if (match) {
      const repo = match[1];
      const res = await fetch(
        `https://api.github.com/repos/${repo}/commits?per_page=1`,
        { headers: { 'Accept': 'application/vnd.github.v3+json' } }
      );
      if (res.ok) {
        const commits = await res.json();
        if (commits.length > 0) {
          lastUpdated = new Date(commits[0].commit.committer.date).toLocaleDateString('en-US', {
            year: 'numeric', month: 'short', day: 'numeric'
          });
        }
      }
    }
  } catch {
    // Fall back to frontmatter value
  }
}
---

<ProjectLayout
  title={project.data.title}
  status={project.data.status}
  techStack={project.data.techStack}
  github={project.data.github}
  demo={project.data.demo}
  lastUpdated={lastUpdated}
>
  <Content />
</ProjectLayout>
