---
interface Props {
  title: string;
  summary: string;
  detail: string;
}

const { title, summary, detail } = Astro.props;
---

<div class="border border-border rounded-[10px] overflow-hidden" data-thinking-card>
  <button
    class="w-full text-left p-6 sm:p-8 hover:bg-bg-sand transition-colors cursor-pointer"
    data-thinking-trigger
    aria-expanded="false"
  >
    <div class="flex items-start justify-between gap-4">
      <div>
        <h2 class="font-heading text-lg font-semibold text-text mb-2">{title}</h2>
        <p class="text-sm text-text-medium leading-relaxed">{summary}</p>
      </div>
      <svg class="w-5 h-5 text-text-muted flex-shrink-0 mt-1 transition-transform" data-thinking-chevron fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </button>

  <div class="hidden px-6 sm:px-8 pb-6 sm:pb-8" data-thinking-detail>
    <div class="text-sm text-text-medium leading-relaxed space-y-3 border-t border-border pt-5">
      <Fragment set:html={detail} />
    </div>
  </div>
</div>
