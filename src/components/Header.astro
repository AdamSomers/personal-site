---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/building', label: 'Building' },
  { href: '/journey', label: 'Journey' },
  { href: '/thinking', label: 'Thinking' },
  { href: '/human', label: 'Human' },
];
---

<header class="border-b border-border bg-bg/80 backdrop-blur-sm sticky top-0 z-50" transition:persist>
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-heading text-lg font-semibold text-text hover:text-accent transition-colors">
      Adam Somers
    </a>

    <div class="flex items-center gap-6">
      <nav class="hidden sm:flex gap-6">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-accent'
                : 'text-text-medium hover:text-accent',
            ]}
          >
            {label}
          </a>
        ))}
      </nav>

      <button
        id="mobile-menu-toggle"
        class="sm:hidden p-2 text-text-medium"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-menu" class="hidden sm:hidden border-t border-border px-6 pb-4">
    {navLinks.map(({ href, label }) => (
      <a
        href={href}
        class:list={[
          'block py-2 text-sm font-medium transition-colors',
          currentPath === href || (href !== '/' && currentPath.startsWith(href))
            ? 'text-accent'
            : 'text-text-medium hover:text-accent',
        ]}
      >
        {label}
      </a>
    ))}
  </nav>
</header>

<script>
  function initMobileMenu() {
    document.getElementById('mobile-menu-toggle')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
  }
  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
